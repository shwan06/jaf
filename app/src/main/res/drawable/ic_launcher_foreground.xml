    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Maze walls -->
    <path
        android:strokeColor="#7C4DFF"
        android:strokeWidth="5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M34,34 H74 V74 H42 V50 H62 V62" />

    <!-- Runner dot at the start -->
    <path
        android:fillColor="#FFD54F"
        android:pathData="M34,74 m-6,0 a6,6 0 1,0 12,0 a6,6 0 1,0 -12,0" />

    <!-- Exit dot -->
