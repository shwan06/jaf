              "А",
              "Я",
              "/a/",
              "/ja/ (ya)"
            ],
            [
              "О",
              "Ё",
              "/o/",
              "/jo/ (yo)"
            ],
            [
              "У",
              "Ю",
              "/u/",
              "/ju/ (yu)"
            ],
            [
              "Э",
              "Е",
              "/e/",
              "/je/ (ye)"
            ],
            [
              "Ы",
              "И",
              "/i/",
              "/i/ (softens)"
            ]
          ]
        },
