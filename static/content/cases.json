{
  "title": "Cases Trainer — Падежи",
  "description": "Russian has six cases. Reading the tables teaches them; drilling them in context makes them stick. Pick a case (or Mixed), read the sentence, and choose the correct form of the word in parentheses.",
  "cases": [
    { "id": "nominative", "name": "Nominative", "ru": "Именительный", "q": "кто? что?", "use": "the subject — the dictionary form" },
    { "id": "genitive", "name": "Genitive", "ru": "Родительный", "q": "кого? чего?", "use": "possession, absence (нет), 'of', after из/у/для/без" },
    { "id": "dative", "name": "Dative", "ru": "Дательный", "q": "кому? чему?", "use": "the indirect object — 'to / for' someone, after к/по" },
    { "id": "accusative", "name": "Accusative", "ru": "Винительный", "q": "кого? что?", "use": "the direct object, and motion after в/на" },
    { "id": "instrumental", "name": "Instrumental", "ru": "Творительный", "q": "кем? чем?", "use": "the instrument/means, 'with', after с/над/под" },
    { "id": "prepositional", "name": "Prepositional", "ru": "Предложный", "q": "о ком? о чём?", "use": "location and topic — after в/на/о" }
  ],
  "drills": [
    { "id": "n1", "case": "nominative", "en": "This is a house.", "prompt": "Это ___.", "base": "дом", "answer": "дом", "options": ["дом", "дома", "дому", "домом"], "explain": "The subject / naming form stays in the nominative — the dictionary form.", "context": "Subject" },
    { "id": "n2", "case": "nominative", "en": "The student is reading.", "prompt": "___ читает.", "base": "студент", "answer": "студент", "options": ["студент", "студента", "студенту", "студентом"], "explain": "Doer of the action → nominative.", "context": "Subject" },
    { "id": "n3", "case": "nominative", "en": "Here is the teacher.", "prompt": "Вот ___.", "base": "учитель", "answer": "учитель", "options": ["учитель", "учителя", "учителю", "учителем"], "explain": "After 'вот' (here is) the noun is named in the nominative.", "context": "Naming" },
    { "id": "n4", "case": "nominative", "en": "Mom is at home.", "prompt": "___ дома.", "base": "мама", "answer": "мама", "options": ["мама", "мамы", "маме", "мамой"], "explain": "Subject of the sentence → nominative.", "context": "Subject" },

    { "id": "g1", "case": "genitive", "en": "I don't have a book.", "prompt": "У меня нет ___.", "base": "книга", "answer": "книги", "options": ["книга", "книги", "книгу", "книгой"], "explain": "After 'нет' (there is no) use the genitive. Feminine -а → -и after к/г/х.", "context": "Negation (нет + genitive)" },
    { "id": "g2", "case": "genitive", "en": "A glass of water.", "prompt": "Стакан ___.", "base": "вода", "answer": "воды", "options": ["вода", "воды", "воду", "водой"], "explain": "'of water' — the genitive expresses 'of'. вода → воды.", "context": "Quantity ('of')" },
    { "id": "g3", "case": "genitive", "en": "I don't have a brother.", "prompt": "У меня нет ___.", "base": "брат", "answer": "брата", "options": ["брат", "брата", "брату", "братом"], "explain": "нет + genitive. Masculine hard stem adds -а.", "context": "Negation (нет + genitive)" },
    { "id": "g4", "case": "genitive", "en": "He is from Moscow.", "prompt": "Он из ___.", "base": "Москва", "answer": "Москвы", "options": ["Москва", "Москвы", "Москве", "Москву"], "explain": "The preposition 'из' (from) takes the genitive. Москва → Москвы.", "context": "After из (from)" },
    { "id": "g5", "case": "genitive", "en": "A cup of tea.", "prompt": "Чашка ___.", "base": "чай", "answer": "чая", "options": ["чай", "чая", "чаю", "чаем"], "explain": "'of tea' → genitive. Soft masculine чай → чая.", "context": "Quantity ('of')" },
    { "id": "g6", "case": "genitive", "en": "It's my father's house.", "prompt": "Это дом моего ___.", "base": "отец", "answer": "отца", "options": ["отец", "отца", "отцу", "отцом"], "explain": "Possession ('father's') → genitive. Note the fleeting -е-: отец → отца.", "context": "Possession" },
    { "id": "g7", "case": "genitive", "en": "I don't have a sister.", "prompt": "У меня нет ___.", "base": "сестра", "answer": "сестры", "options": ["сестра", "сестры", "сестру", "сестрой"], "explain": "нет + genitive. сестра → сестры.", "context": "Negation (нет + genitive)" },
    { "id": "g8", "case": "genitive", "en": "Tea without sugar.", "prompt": "Чай без ___.", "base": "сахар", "answer": "сахара", "options": ["сахар", "сахара", "сахару", "сахаром"], "explain": "The preposition 'без' (without) takes the genitive.", "context": "After без (without)" },
    { "id": "g9", "case": "genitive", "en": "A present for mom.", "prompt": "Подарок для ___.", "base": "мама", "answer": "мамы", "options": ["мама", "мамы", "маме", "мамой"], "explain": "The preposition 'для' (for) takes the genitive. мама → мамы.", "context": "After для (for)" },
    { "id": "g10", "case": "genitive", "en": "Near the school.", "prompt": "Около ___.", "base": "школа", "answer": "школы", "options": ["школа", "школы", "школе", "школу"], "explain": "'около' (near) takes the genitive. школа → школы.", "context": "After около (near)" },

    { "id": "d1", "case": "dative", "en": "I'm going to the doctor.", "prompt": "Я иду к ___.", "base": "врач", "answer": "врачу", "options": ["врач", "врача", "врачу", "врачом"], "explain": "The preposition 'к' (towards) takes the dative. врач → врачу.", "context": "After к (towards)" },
    { "id": "d2", "case": "dative", "en": "I gave a present to my brother.", "prompt": "Я дал подарок ___.", "base": "брат", "answer": "брату", "options": ["брат", "брата", "брату", "братом"], "explain": "The recipient (to whom) is the dative. брат → брату.", "context": "Indirect object" },
    { "id": "d3", "case": "dative", "en": "I'm calling mom.", "prompt": "Я звоню ___.", "base": "мама", "answer": "маме", "options": ["мама", "мамы", "маме", "мамой"], "explain": "'звонить' (to call) takes the dative — you call 'to' someone. мама → маме.", "context": "Verb takes dative" },
    { "id": "d4", "case": "dative", "en": "I help my friend.", "prompt": "Я помогаю ___.", "base": "друг", "answer": "другу", "options": ["друг", "друга", "другу", "другом"], "explain": "'помогать' (to help) takes the dative. друг → другу.", "context": "Verb takes dative" },
    { "id": "d5", "case": "dative", "en": "I gave the book to the teacher.", "prompt": "Я дал книгу ___.", "base": "учитель", "answer": "учителю", "options": ["учитель", "учителя", "учителю", "учителем"], "explain": "Recipient → dative. Soft stem учитель → учителю.", "context": "Indirect object" },
    { "id": "d6", "case": "dative", "en": "I'm walking along the street.", "prompt": "Я иду по ___.", "base": "улица", "answer": "улице", "options": ["улица", "улицы", "улице", "улицу"], "explain": "The preposition 'по' (along) takes the dative. улица → улице.", "context": "After по (along)" },
    { "id": "d7", "case": "dative", "en": "A present for my sister.", "prompt": "Подарок ___.", "base": "сестра", "answer": "сестре", "options": ["сестра", "сестры", "сестре", "сестрой"], "explain": "The recipient ('to my sister') → dative. сестра → сестре.", "context": "Indirect object" },
    { "id": "d8", "case": "dative", "en": "I'm calling dad.", "prompt": "Я звоню ___.", "base": "отец", "answer": "отцу", "options": ["отец", "отца", "отцу", "отцом"], "explain": "'звонить' + dative. Fleeting vowel: отец → отцу.", "context": "Verb takes dative" },

    { "id": "a1", "case": "accusative", "en": "I see a book.", "prompt": "Я вижу ___.", "base": "книга", "answer": "книгу", "options": ["книга", "книги", "книгу", "книгой"], "explain": "Direct object → accusative. Feminine -а → -у.", "context": "Direct object" },
    { "id": "a2", "case": "accusative", "en": "I love mom.", "prompt": "Я люблю ___.", "base": "мама", "answer": "маму", "options": ["мама", "мамы", "маме", "маму"], "explain": "Direct object → accusative. мама → маму.", "context": "Direct object" },
    { "id": "a3", "case": "accusative", "en": "I'm reading a newspaper.", "prompt": "Я читаю ___.", "base": "газета", "answer": "газету", "options": ["газета", "газеты", "газете", "газету"], "explain": "Direct object → accusative. газета → газету.", "context": "Direct object" },
    { "id": "a4", "case": "accusative", "en": "I see my brother.", "prompt": "Я вижу ___.", "base": "брат", "answer": "брата", "options": ["брат", "брата", "брату", "братом"], "explain": "Animate masculine: accusative = genitive. брат → брата.", "context": "Animate (acc = gen)" },
    { "id": "a5", "case": "accusative", "en": "I know Anna.", "prompt": "Я знаю ___.", "base": "Анна", "answer": "Анну", "options": ["Анна", "Анны", "Анне", "Анну"], "explain": "Direct object → accusative. Анна → Анну.", "context": "Direct object" },
    { "id": "a6", "case": "accusative", "en": "I'm going to school.", "prompt": "Я иду в ___.", "base": "школа", "answer": "школу", "options": ["школа", "школы", "школе", "школу"], "explain": "Motion 'в/на + accusative' (going INTO). школа → школу.", "context": "Motion (в/на + acc)" },
    { "id": "a7", "case": "accusative", "en": "I drink water.", "prompt": "Я пью ___.", "base": "вода", "answer": "воду", "options": ["вода", "воды", "воде", "воду"], "explain": "Direct object → accusative. вода → воду.", "context": "Direct object" },
    { "id": "a8", "case": "accusative", "en": "I see a window.", "prompt": "Я вижу ___.", "base": "окно", "answer": "окно", "options": ["окно", "окна", "окну", "окном"], "explain": "Inanimate neuter: accusative = nominative. окно stays окно.", "context": "Inanimate (acc = nom)" },
    { "id": "a9", "case": "accusative", "en": "I met a friend.", "prompt": "Я встретил ___.", "base": "друг", "answer": "друга", "options": ["друг", "друга", "другу", "другом"], "explain": "Animate masculine: accusative = genitive. друг → друга.", "context": "Animate (acc = gen)" },

    { "id": "i1", "case": "instrumental", "en": "I'm writing with a pen.", "prompt": "Я пишу ___.", "base": "ручка", "answer": "ручкой", "options": ["ручка", "ручки", "ручку", "ручкой"], "explain": "The instrument ('with a pen') → instrumental. ручка → ручкой.", "context": "Instrument ('with')" },
    { "id": "i2", "case": "instrumental", "en": "Tea with sugar.", "prompt": "Чай с ___.", "base": "сахар", "answer": "сахаром", "options": ["сахар", "сахара", "сахару", "сахаром"], "explain": "The preposition 'с' (with, together) takes the instrumental. сахар → сахаром.", "context": "After с (with)" },
    { "id": "i3", "case": "instrumental", "en": "I'm talking with a friend.", "prompt": "Я говорю с ___.", "base": "друг", "answer": "другом", "options": ["друг", "друга", "другу", "другом"], "explain": "'с' (with) + instrumental. друг → другом.", "context": "After с (with)" },
    { "id": "i4", "case": "instrumental", "en": "He works as a doctor.", "prompt": "Он работает ___.", "base": "врач", "answer": "врачом", "options": ["врач", "врача", "врачу", "врачом"], "explain": "'работать + instrumental' = to work AS something. врач → врачом.", "context": "Profession (работать + instr)" },
    { "id": "i5", "case": "instrumental", "en": "Coffee with milk.", "prompt": "Кофе с ___.", "base": "молоко", "answer": "молоком", "options": ["молоко", "молока", "молоку", "молоком"], "explain": "'с' (with) + instrumental. Neuter молоко → молоком.", "context": "After с (with)" },
    { "id": "i6", "case": "instrumental", "en": "I'm going with mom.", "prompt": "Я иду с ___.", "base": "мама", "answer": "мамой", "options": ["мама", "мамы", "маме", "мамой"], "explain": "'с' (together with) + instrumental. мама → мамой.", "context": "After с (with)" },
    { "id": "i7", "case": "instrumental", "en": "Above the table.", "prompt": "Над ___.", "base": "стол", "answer": "столом", "options": ["стол", "стола", "столу", "столом"], "explain": "The preposition 'над' (above) takes the instrumental. стол → столом.", "context": "After над (above)" },
    { "id": "i8", "case": "instrumental", "en": "I'm proud of my sister.", "prompt": "Я горжусь ___.", "base": "сестра", "answer": "сестрой", "options": ["сестра", "сестры", "сестре", "сестрой"], "explain": "'гордиться' (to be proud of) takes the instrumental. сестра → сестрой.", "context": "Verb takes instrumental" },

    { "id": "p1", "case": "prepositional", "en": "We're talking about the lesson.", "prompt": "Мы говорим о ___.", "base": "урок", "answer": "уроке", "options": ["урок", "урока", "уроку", "уроке"], "explain": "'о' (about) takes the prepositional. урок → уроке.", "context": "After о (about)" },
    { "id": "p2", "case": "prepositional", "en": "She lives in Moscow.", "prompt": "Она живёт в ___.", "base": "Москва", "answer": "Москве", "options": ["Москва", "Москвы", "Москве", "Москву"], "explain": "Location 'в + prepositional' (being IN). Москва → Москве.", "context": "Location (в/на)" },
    { "id": "p3", "case": "prepositional", "en": "The book is on the table.", "prompt": "Книга на ___.", "base": "стол", "answer": "столе", "options": ["стол", "стола", "столу", "столе"], "explain": "Location 'на + prepositional' (resting ON). стол → столе.", "context": "Location (в/на)" },
    { "id": "p4", "case": "prepositional", "en": "I'm thinking about mom.", "prompt": "Я думаю о ___.", "base": "мама", "answer": "маме", "options": ["мама", "мамы", "маму", "маме"], "explain": "'о' (about) + prepositional. мама → маме.", "context": "After о (about)" },
    { "id": "p5", "case": "prepositional", "en": "We're at school.", "prompt": "Мы в ___.", "base": "школа", "answer": "школе", "options": ["школа", "школы", "школе", "школу"], "explain": "Location 'в + prepositional'. школа → школе.", "context": "Location (в/на)" },
    { "id": "p6", "case": "prepositional", "en": "About my brother.", "prompt": "О ___.", "base": "брат", "answer": "брате", "options": ["брат", "брата", "брату", "брате"], "explain": "'о' (about) + prepositional. брат → брате.", "context": "After о (about)" },
    { "id": "p7", "case": "prepositional", "en": "In the city.", "prompt": "В ___.", "base": "город", "answer": "городе", "options": ["город", "города", "городу", "городе"], "explain": "Location 'в + prepositional'. город → городе.", "context": "Location (в/на)" },
    { "id": "p8", "case": "prepositional", "en": "The cat sleeps on the sofa.", "prompt": "Кот спит на ___.", "base": "диван", "answer": "диване", "options": ["диван", "дивана", "дивану", "диване"], "explain": "Location 'на + prepositional'. диван → диване.", "context": "Location (в/на)" }
  ]
}
